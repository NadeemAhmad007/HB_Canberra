# ── Database (Neon) ──────────────────────────────────────────────────────
# Get your connection string from https://console.neon.tech
DATABASE_URL=postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/houseboat-canberra?sslmode=require

# ── Google Sheets / Apps Script ──────────────────────────────────────────
# After deploying scripts/pms/Code.gs as a web app, paste the URL here
APPS_SCRIPT_URL=https://script.google.com/macros/s/your-script-id/exec
# Must match AUTH_TOKEN in Code.gs — set this to a random secret string
APPS_SCRIPT_TOKEN=change-this-to-a-random-secret

# ── Stripe (optional — for payment processing) ───────────────────────────
# Get from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# Get from https://dashboard.stripe.com/webhooks (create endpoint for /api/stripe/webhook)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Resend (optional — for email confirmations) ──────────────────────────
# Get from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
